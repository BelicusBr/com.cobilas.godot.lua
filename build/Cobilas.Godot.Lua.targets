<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<Import Project="Cobilas.Godot.Lua.props"/>
	<PropertyGroup>
		<!--<GDLuaPackFolde>$(NuGetPackageRoot)\cobilas.godot.lua\1.2.9</GDLuaPackFolde>-->
		<GDLuaLibFolder>$(GDLuaPackFolde)\lib\luadlls</GDLuaLibFolder>
		<OutGDLuaLibs>$(OutputPath)luadlls</OutGDLuaLibs>
	</PropertyGroup>
	<ItemGroup>
		<GDLuaLibFiles Include="$(GDLuaLibFolder)\**\*"/>
		<GDnlibFile Include="$(GDLuaPackFolde)\lib\com.cobilas.godot.lua.gdnlib"/>
	</ItemGroup>
	<Target Name="CopyLuaLibs" BeforeTargets="BeforeBuild" AfterTargets="ResolvePackageAssets">

		<Message Text="Starting the copying of the Lua libraries." Importance="high"/>
		
		<Copy SourceFiles="@(GDLuaLibFiles)"
			  DestinationFiles="@(GDLuaLibFiles->'$(OutputPath)luadlls\%(RecursiveDir)%(Filename)%(Extension)')"
			  SkipUnchangedFiles="true"/>

		<Message Text="Starting the copy of the .gdnlib file." Importance="high" Condition="!Exists('$(GDnlibFile)')"/>
		
		<Copy SourceFiles="@(GDnlibFile)"
			  DestinationFiles="@(GDnlibFile->'$(MSBuildProjectDirectory)\com.cobilas.godot.lua.gdnlib')"
			  SkipUnchangedFiles="true"
			  Condition="!Exists('$(GDnlibFile)')"/>

		<Message Text="CopyLuaLibs completed." Importance="high"/>
	</Target>
</Project>